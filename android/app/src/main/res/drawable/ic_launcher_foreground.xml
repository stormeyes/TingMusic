<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground: a vinyl record (black disc + faint grooves + red
     center label), matching the app's vinyl placeholder motif. Drawn within the
     center safe zone of the 108dp viewport. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- disc body -->
    <path
        android:fillColor="#0E0E0E"
        android:pathData="M24,54 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0 z" />
    <!-- outer groove -->
    <path
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="0.8"
        android:fillColor="#00000000"
        android:pathData="M27,54 a27,27 0 1,0 54,0 a27,27 0 1,0 -54,0 z" />
    <!-- inner groove -->
    <path
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="0.8"
        android:fillColor="#00000000"
        android:pathData="M34,54 a20,20 0 1,0 40,0 a20,20 0 1,0 -40,0 z" />
    <!-- red center label -->
    <path
        android:fillColor="#D33A31"
        android:pathData="M43,54 a11,11 0 1,0 22,0 a11,11 0 1,0 -22,0 z" />
    <!-- spindle hole -->
    <path
        android:fillColor="#0E0E0E"
        android:pathData="M51.5,54 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0 z" />
</vector>
